{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "jest",
    "e2e:build": "detox build --configuration ios.sim.development",
    "e2e:build:release": "detox build --configuration ios.sim.release",
    "e2e:test": "detox test --configuration ios.sim.development",
    "e2e:test:release": "detox test --configuration ios.sim.release"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "<rootDir>/e2e/"
    ],
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|supercluster|kdbush)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@travel-companion/shared$": "<rootDir>/../../packages/shared/src/index.ts"
    }
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-navigation/bottom-tabs": "^7.15.7",
    "@react-navigation/drawer": "^7.9.4",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "@react-navigation/stack": "^7.8.5",
    "@supabase/supabase-js": "^2.99.2",
    "expo": "~55.0.6",
    "expo-auth-session": "~55.0.8",
    "expo-clipboard": "~55.0.9",
    "expo-image": "~55.0.8",
    "expo-image-manipulator": "^55.0.11",
    "expo-image-picker": "~55.0.12",
    "expo-localization": "^55.0.11",
    "expo-location": "~55.1.2",
    "expo-media-library": "~55.0.9",
    "expo-secure-store": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.9",
    "i18next": "^26.0.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.2",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "^0.7.4",
    "supercluster": "^8.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.84.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/detox": "^17.14.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "@types/supercluster": "^7.1.3",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^55.0.12",
    "detox": "^20.50.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-circus": "^30.3.0",
    "jest-expo": "^55.0.11",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
